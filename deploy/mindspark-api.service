[Unit]
Description=MindSpark API
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/mindspark
ExecStart=/usr/bin/npm run start -w apps/api
Restart=always
RestartSec=5
Environment=NODE_ENV=production
EnvironmentFile=/var/www/mindspark/apps/api/.env
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
